#!/bin/bash

set -euo pipefail
shopt -s nullglob

ORIG_ARGV=("$@")
REMOTE_LABEL=""

readonly CONF_FILE=/etc/btrctl.conf

HOST_LABEL=$(hostname)
BTRFS_MOUNT_POINT=/btrfs
SUBVOLUMES=(@)
TRUNK_MOUNT_POINT=/trunk

SSH="${SUDO_USER:+sudo -u "$SUDO_USER"} /usr/bin/ssh"

if [ -f "$CONF_FILE" ]; then
  source "$CONF_FILE"
fi

OUT_RESET=''
OUT_BOLD=''
ERR_RESET=''
ERR_RED=''
ERR_YELLOW=''
ERR_BLUE=''
ERR_WHITE=''

if [ -z "${NO_COLOR:-}" ]; then
  if [ -t 1 ]; then
    OUT_RESET=$'\033[0m'
    OUT_BOLD=$'\033[1m'
  fi

  if [ -t 2 ]; then
    ERR_RESET=$'\033[0m'
    ERR_RED=$'\033[1;31m'
    ERR_YELLOW=$'\033[1;33m'
    ERR_BLUE=$'\033[1;34m'
    ERR_WHITE=$'\033[1;37m'
  fi
fi

_log() {
  local color="$1" level="$2"; shift 2
  local label=""
  [ -n "$REMOTE_LABEL" ] && label="${ERR_WHITE}[${REMOTE_LABEL}]${ERR_RESET} "
  echo "${color}[${level}]${ERR_RESET} ${label}$*" >&2
}

_die() {
  _log "$ERR_RED" ERROR "$@"
  exit 1
}

_error() {
  _log "$ERR_RED" ERROR "$@"
}

_warn() {
  _log "$ERR_YELLOW" WARN "$@"
}

_info() {
  _log "$ERR_BLUE" INFO "$@"
}

CONF_OVERLAY_FILE="${BTRCTL_CONF:-}"
if [ -n "$CONF_OVERLAY_FILE" ]; then
  [ -f "$CONF_OVERLAY_FILE" ] || _die "config overlay file not found: ${CONF_OVERLAY_FILE}"
  source "$CONF_OVERLAY_FILE"
fi

_require_root() {
  [ "$(id -u)" -eq 0 ] && return
  command -v sudo > /dev/null 2>&1 || _die "this command must be run as root"
  if [ -n "$CONF_OVERLAY_FILE" ]; then
    exec sudo BTRCTL_CONF="$CONF_OVERLAY_FILE" -- "$0" "${ORIG_ARGV[@]}"
  else
    exec sudo -- "$0" "${ORIG_ARGV[@]}"
  fi
}

_confirm() {
  local prompt="$1" answer
  read -r -p "${prompt} [y/N] " answer || answer=""
  case "$answer" in
    y|Y) return 0 ;;
    *) return 1 ;;
  esac
}

_update_symlink() {
  local target="$1" link_path="$2"
  if [ -e "$link_path" ] && [ ! -L "$link_path" ]; then
    _warn "${link_path} exists and is not a symlink"
    return 1
  fi
  ln -sfn "$target" "$link_path"
}

_mount_point() {
  _info "Mounting ${1} ..."
  mount "$1"
}

_umount_point() {
  _info "Unmounting ${1} ..."
  umount "$1"
}

_ensure_btrfs_mounted() {
  _require_root
  mountpoint -q "$BTRFS_MOUNT_POINT" || _mount_point "$BTRFS_MOUNT_POINT"
}

_run_snapshot_hook() {
  local hook="$1"
  local snapshot_dir="${2:-}"
  local script="${BTRFS_MOUNT_POINT}/.btrctl/${hook}"
  [ -e "$script" ] || return 0

  if [ ! -x "$script" ]; then
    _warn "${script} exists but is not executable"
    return 0
  fi

  _info "Running ${hook} hook ..."
  if [ -n "$snapshot_dir" ]; then
    (cd "$BTRFS_MOUNT_POINT" && BTRFS_MOUNT_POINT="$BTRFS_MOUNT_POINT" SNAPSHOT_DIR="$snapshot_dir" "$script")
  else
    (cd "$BTRFS_MOUNT_POINT" && BTRFS_MOUNT_POINT="$BTRFS_MOUNT_POINT" "$script")
  fi
}

_ensure_trunk_mounted() {
  _require_root
  mountpoint -q "$TRUNK_MOUNT_POINT" || _die "${TRUNK_MOUNT_POINT} is not mounted"
}

_snapshot_subvol_path() {
  local set_dir="$1" timestamp="$2" label="$3" subvol="$4"
  echo "${set_dir}/@snapshot-${timestamp}-${label}-${subvol}"
}

_is_set_name() {
  case "$1" in
    [0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9]-[0-9][0-9][0-9][0-9][0-9][0-9]) return 0 ;;
    *) return 1 ;;
  esac
}

_read_tag() {
  [ -f "${1}/.btrctl/tag" ] && cat "${1}/.btrctl/tag" || true
}

_write_tag() {
  local dir="$1" value="$2"
  if [ -n "$value" ]; then
    mkdir -p "${dir}/.btrctl"
    printf '%s\n' "$value" > "${dir}/.btrctl/tag"
  else
    rm -f "${dir}/.btrctl/tag"
  fi
}

_next_most_recent_set() {
  local dir="$1" d name
  local names=()
  for d in "$dir"/*/; do
    name=$(basename "$d")
    _is_set_name "$name" && names+=("$name")
  done
  if [ "${#names[@]}" -gt 0 ]; then
    printf '%s\n' "${names[@]}" | sort | tail -n1
  fi
}

_delete_set_dir() {
  local set_dir="$1" subvol_path
  _info "This will permanently delete: ${set_dir}"
  _confirm "Proceed?" || { _info "Aborted."; return 1; }
  _info "Deleting snapshots ..."
  for subvol_path in "$set_dir"/@snapshot-*; do
    btrfs subvolume delete "$subvol_path"
  done
  rm -rf "$set_dir"
}

_remote_sudo_prompt() {
  local host="$1" m='' r=''
  if [ -z "${NO_COLOR:-}" ]; then
    m=$'\033[1;95m'
    r=$'\033[0m'
  fi
  printf '%s[remote sudo]%s password for %s: ' "$m" "$r" "$host"
}

_ssh() {
  local host="$1"; shift
  $SSH "$host" "$@"
}

_ssh_tty() {
  local host="$1"; shift
  $SSH -t "$host" "$@"
}

_dispatch_remote() {
  local host="$1" subcmd="$2"; shift 2
  local cmd arg
  cmd="sudo -p $(printf '%q' "$(_remote_sudo_prompt "$host")") btrctl --remote-label $(printf '%q' "$host") ${subcmd}"
  for arg in "$@"; do
    cmd+=" $(printf '%q' "$arg")"
  done
  _ssh_tty "$host" "$cmd"
}

_remote_root() {
  local host="$1" pw="$2"
  shift 2
  printf '%s\n' "$pw" | _ssh "$host" "sudo -S -p '' sh -c $(printf '%q' "$*")"
}

_remote_config() {
  local host="$1" raw line
  raw=$(_ssh "$host" "btrctl config") || _die "failed to fetch remote config from ${host}"

  local subvolumes_line=""
  REMOTE_HOST_LABEL=""
  REMOTE_BTRFS_MOUNT_POINT=""
  REMOTE_SUBVOLUMES=()

  while IFS= read -r line; do
    case "$line" in
      HOST_LABEL=*)
        REMOTE_HOST_LABEL="${line#HOST_LABEL=}"
        ;;
      BTRFS_MOUNT_POINT=*)
        REMOTE_BTRFS_MOUNT_POINT="${line#BTRFS_MOUNT_POINT=}"
        ;;
      SUBVOLUMES=*)
        subvolumes_line="${line#SUBVOLUMES=}"
        ;;
    esac
  done <<< "$raw"

  [ -n "$subvolumes_line" ] && eval "REMOTE_SUBVOLUMES=${subvolumes_line}"

  [ -n "$REMOTE_HOST_LABEL" ] || _die "could not determine HOST_LABEL from ${host}"
  [ -n "$REMOTE_BTRFS_MOUNT_POINT" ] || _die "could not determine BTRFS_MOUNT_POINT from ${host}"
  [ "${#REMOTE_SUBVOLUMES[@]}" -gt 0 ] || _die "could not determine SUBVOLUMES from ${host}"
}

_consume_opt_value() {
  local -n _out="$1"; shift
  [ $# -ge 2 ] || _die "$1 requires an argument"
  _out="$2"
}

_parse_host_only_args() {
  local cmd_name="$1" varname="$2"; shift 2
  local -n _out="$varname"
  _out=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --host)
        _consume_opt_value "$varname" "$@"
        shift 2
        ;;
      *)
        _die "${cmd_name}: unknown argument: $1"
        ;;
    esac
  done
}

_maybe_dispatch_remote() {
  local host="$1" subcmd="$2"; shift 2
  [ -n "$host" ] || return 1
  _dispatch_remote "$host" "$subcmd" "$@"
  return 0
}

cmd_mount() {
  local host

  _parse_host_only_args mount host "$@"
  _maybe_dispatch_remote "$host" mount && return

  _require_root
  if mountpoint -q "$BTRFS_MOUNT_POINT"; then
    _warn "${BTRFS_MOUNT_POINT} is already mounted"
    return
  fi
  _mount_point "$BTRFS_MOUNT_POINT"
  _info "Mounted ${BTRFS_MOUNT_POINT}"
}

cmd_umount() {
  local host

  _parse_host_only_args umount host "$@"
  _maybe_dispatch_remote "$host" umount && return

  _require_root
  if ! mountpoint -q "$BTRFS_MOUNT_POINT"; then
    _warn "${BTRFS_MOUNT_POINT} is already unmounted"
    return
  fi
  _umount_point "$BTRFS_MOUNT_POINT"
  _info "Unmounted ${BTRFS_MOUNT_POINT}"
}

cmd_snapshot() {
  local tag="" host=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --tag)
        _consume_opt_value tag "$@"
        shift 2
        ;;
      --host)
        _consume_opt_value host "$@"
        shift 2
        ;;
      *)
        _die "snapshot: unknown argument: $1"
        ;;
    esac
  done

  _maybe_dispatch_remote "$host" snapshot --tag "$tag" && return
  _ensure_btrfs_mounted
  _run_snapshot_hook pre-snapshot || \
    _die "pre-snapshot hook failed; aborting snapshot"

  local snapshots_subvol="@snapshots"
  local now
  now=$(date +'%Y-%m-%d-%H%M%S')
  local snapshot_dir
  snapshot_dir="$(cd "$BTRFS_MOUNT_POINT" && pwd -P)/${snapshots_subvol}/${now}"

  mkdir -p "$snapshot_dir"

  _info "Creating snapshot set ${now} ..."
  local subvol snapshot_name
  (
    cd "$BTRFS_MOUNT_POINT"
    for subvol in "${SUBVOLUMES[@]}"; do
      snapshot_name="@snapshot-${now}-${HOST_LABEL}-${subvol}"
      if ! btrfs subvolume snapshot -r "$subvol" "${snapshots_subvol}/${now}/${snapshot_name}"; then
        _error "failed to snapshot subvolume '${subvol}'; partial snapshot set at ${snapshot_dir} requires clean up"
        exit 1
      fi
    done
  ) || exit 1

  _write_tag "$snapshot_dir" "$tag"
  _info "Setting latest -> ${now}"
  _update_symlink "$now" "${BTRFS_MOUNT_POINT}/${snapshots_subvol}/latest" || true
  _run_snapshot_hook post-snapshot "$snapshot_dir" || \
    _die "post-snapshot hook failed"
  _info "Created snapshot set: ${now}${tag:+ (tag: ${tag})}"
}

cmd_list() {
  local host

  _parse_host_only_args list host "$@"
  _maybe_dispatch_remote "$host" list && return
  _ensure_btrfs_mounted

  local snapshots_dir="${BTRFS_MOUNT_POINT}/@snapshots"
  if [ ! -d "$snapshots_dir" ]; then
    _info "No snapshots found."
    return
  fi

  local latest_target=""
  if [ -L "${snapshots_dir}/latest" ]; then
    latest_target=$(basename "$(readlink -f "${snapshots_dir}/latest")")
  fi

  local -A trunk_indicators=()
  local link link_name link_target
  for link in "${snapshots_dir}"/trunk_*; do
    [ -L "$link" ] || continue
    link_name=$(basename "$link")
    link_target=$(readlink -f "$link" 2>/dev/null || true)
    [ -n "$link_target" ] && [ -d "$link_target" ] || continue
    link_target=$(basename "$link_target")
    if [ -n "${trunk_indicators[$link_target]:-}" ]; then
      trunk_indicators[$link_target]="${trunk_indicators[$link_target]}, ${link_name}"
    else
      trunk_indicators[$link_target]="$link_name"
    fi
  done

  local -a set_names=() tags=() flags_list=()
  local host_width=${#HOST_LABEL} set_width=3 tag_width=3 flags_width=5
  [ "$host_width" -ge 4 ] || host_width=4

  local found=0 d set_name tag flags
  for d in "$snapshots_dir"/*/; do
    set_name=$(basename "$d")
    _is_set_name "$set_name" || continue
    tag=$(_read_tag "${d%/}")
    flags="${trunk_indicators[$set_name]:-}"
    if [ "$set_name" = "$latest_target" ]; then
      if [ -n "$flags" ]; then
        flags="latest, ${flags}"
      else
        flags="latest"
      fi
    fi
    set_names+=("$set_name")
    tags+=("$tag")
    flags_list+=("$flags")
    [ "${#set_name}" -le "$set_width" ] || set_width=${#set_name}
    [ "${#tag}" -le "$tag_width" ] || tag_width=${#tag}
    [ "${#flags}" -le "$flags_width" ] || flags_width=${#flags}
    found=1
  done

  printf '%s%-*s    %-*s    %-*s    %-*s%s\n' \
    "$OUT_BOLD" "$host_width" "HOST" "$set_width" "SET" \
    "$tag_width" "TAG" "$flags_width" "FLAGS" "$OUT_RESET"
  local i
  for i in "${!set_names[@]}"; do
    printf '%-*s    %-*s    %-*s    %-*s\n' \
      "$host_width" "$HOST_LABEL" "$set_width" "${set_names[i]}" \
      "$tag_width" "${tags[i]}" "$flags_width" "${flags_list[i]}"
  done
  [ "$found" -eq 1 ] || _info "No snapshot sets found."
}

cmd_latest() {
  local host

  _parse_host_only_args latest host "$@"
  _maybe_dispatch_remote "$host" latest && return
  _ensure_btrfs_mounted

  local snapshots_dir="${BTRFS_MOUNT_POINT}/@snapshots"
  local latest_link="${snapshots_dir}/latest"
  [ -L "$latest_link" ] || _die "no ${latest_link} symlink found"

  basename "$(readlink -f "$latest_link")"
}

cmd_rm() {
  local host="" set_name=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --host)
        _consume_opt_value host "$@"
        shift 2
        ;;
      -*)
        _die "rm: unknown option: $1"
        ;;
      *)
        [ -z "$set_name" ] || _die "rm: unexpected extra argument: $1"
        set_name="$1"
        shift
        ;;
    esac
  done
  [ -n "$set_name" ] || _die "rm: SET_NAME is required"

  _maybe_dispatch_remote "$host" rm "$set_name" && return
  _ensure_btrfs_mounted

  local snapshots_dir="${BTRFS_MOUNT_POINT}/@snapshots"
  local set_dir="${snapshots_dir}/${set_name}"
  [ -d "$set_dir" ] || _die "no such snapshot set: ${set_dir}"

  _delete_set_dir "$set_dir" || return 1

  local latest_link="${snapshots_dir}/latest"
  if [ -L "$latest_link" ] && [ "$(readlink "$latest_link")" = "$set_name" ]; then
    local next
    next=$(_next_most_recent_set "$snapshots_dir")
    if [ -n "$next" ]; then
      _info "Setting latest -> ${next}"
      _update_symlink "$next" "$latest_link" || true
    else
      rm -f "$latest_link"
    fi
  fi

  _info "Removed snapshot set: ${set_name}"
}

cmd_tag() {
  local host="" set_name="" tag_value="" got_set=0 got_tag=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --host)
        _consume_opt_value host "$@"
        shift 2
        ;;
      -*)
        _die "tag: unknown option: $1"
        ;;
      *)
        if [ "$got_set" -eq 0 ]; then
          set_name="$1"
          got_set=1
        elif [ "$got_tag" -eq 0 ]; then
          tag_value="$1"
          got_tag=1
        else
          _die "tag: unexpected extra argument: $1"
        fi
        shift
        ;;
    esac
  done
  [ "$got_set" -eq 1 ] || _die "tag: usage: tag SET_ID TAG_NAME"
  [ "$got_tag" -eq 1 ] || _die "tag: usage: tag SET_ID TAG_NAME (empty string clears the tag)"

  _maybe_dispatch_remote "$host" tag "$set_name" "$tag_value" && return
  _ensure_btrfs_mounted

  local snapshots_dir="${BTRFS_MOUNT_POINT}/@snapshots"
  local set_dir="${snapshots_dir}/${set_name}"
  [ -d "$set_dir" ] || _die "no such snapshot set: ${set_dir}"

  _write_tag "$set_dir" "$tag_value"
  if [ -n "$tag_value" ]; then
    _info "Tagged ${set_name}: ${tag_value}"
  else
    _info "Cleared tag for ${set_name}"
  fi
}

_require_btrctl_marker() {
  local dir="$1"
  [ -f "${dir}/.btrctl" ] || \
    _die "${dir} exists but is not configured for btrctl (missing ${dir}/.btrctl)"
}

_ensure_trunk_host_subvol() {
  local dir="$1"
  if [ ! -e "$dir" ]; then
    _info "Creating trunk subvolume: ${dir}"
    btrfs subvolume create "$dir" > /dev/null
    : > "${dir}/.btrctl"
  elif ! btrfs subvolume show "$dir" > /dev/null 2>&1; then
    _die "${dir} exists but is not a btrfs subvolume"
  else
    _require_btrctl_marker "$dir"
  fi
}
_trunk_id() {
  local trunk_id_file="${TRUNK_MOUNT_POINT}/.btrctl/trunk-id"
  [ -f "$trunk_id_file" ] || _die "missing ${trunk_id_file}"
  local trunk_id
  trunk_id=$(cat "$trunk_id_file")
  [ -n "$trunk_id" ] || _die "${trunk_id_file} is empty"
  echo "$trunk_id"
}

cmd_trunk_id() {
  [ $# -eq 0 ] || _die "trunk id: usage: trunk id"
  _ensure_trunk_mounted
  _trunk_id
}

cmd_trunk_backup() {
  local host="" set_name=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --host)
        _consume_opt_value host "$@"
        shift 2
        ;;
      -*)
        _die "trunk backup: unknown option: $1"
        ;;
      *)
        [ -z "$set_name" ] || _die "trunk backup: unexpected extra argument: $1"
        _is_set_name "$1" || _die "trunk backup: invalid SET_NAME: $1"
        set_name="$1"
        shift
        ;;
    esac
  done
  _require_root
  _require_trunk_uuid
  _ensure_trunk_mounted

  local trunk_id
  trunk_id=$(_trunk_id)

  _trunk_backup "$trunk_id" "$host" "$set_name"
}

_src_run() {
  if [ -n "${SRC_HOST:-}" ]; then
    _remote_root "$SRC_HOST" "$SRC_PW" "$1"
  else
    sh -c "$1"
  fi
}

_src_send_receive() {
  if [ -n "${SRC_HOST:-}" ]; then
    printf '%s\n' "$SRC_PW" | _ssh "$SRC_HOST" "sudo -S -p '' $1 2>/dev/null" | btrfs receive "$2"
  else
    eval "$1" | btrfs receive "$2"
  fi
}

_copy_set_metadata() {
  local src_set_dir="$1" target_set_dir="$2"
  local src_metadata_dir="${src_set_dir}/.btrctl" target_metadata_dir="${target_set_dir}/.btrctl"
  local invalid_path metadata_state

  metadata_state=$(_src_run "if test -e '${src_metadata_dir}' || test -L '${src_metadata_dir}'; then printf present; else printf absent; fi") || {
    _error "failed to inspect snapshot metadata: ${src_metadata_dir}"
    return 1
  }
  [ "$metadata_state" = absent ] && return 0
  if [ "$metadata_state" != present ]; then
    _error "could not determine snapshot metadata state: ${src_metadata_dir}"
    return 1
  fi
  if ! _src_run "test -d '${src_metadata_dir}' && test ! -L '${src_metadata_dir}'"; then
    _error "snapshot metadata is not a directory: ${src_metadata_dir}"
    return 1
  fi

  invalid_path=$(_src_run "find '${src_metadata_dir}' -xdev \\( -type l -o \\( ! -type d -a ! -type f \\) \\) -print -quit") || {
    _error "failed to inspect snapshot metadata: ${src_metadata_dir}"
    return 1
  }
  if [ -n "$invalid_path" ]; then
    _error "snapshot metadata contains an unsupported file type: ${invalid_path}"
    return 1
  fi

  if ! _src_run "tar --one-file-system --hard-dereference -C '${src_set_dir}' -cf - .btrctl" \
    | tar --no-same-owner --no-same-permissions --touch -C "$target_set_dir" -xf -; then
    _error "failed to copy snapshot metadata from ${src_metadata_dir}"
    return 1
  fi

  find "$target_metadata_dir" -type d -exec chmod 755 {} +
  find "$target_metadata_dir" -type f -exec chmod 644 {} +
}

_trunk_backup() {
  local trunk_id="$1" host="${2:-}" set_name="${3:-}"
  local label snapshots_dir subvols

  SRC_HOST=""
  SRC_PW=""
  if [ -n "$host" ]; then
    SRC_HOST="$host"
    _remote_config "$host"
    label="$REMOTE_HOST_LABEL"
    snapshots_dir="${REMOTE_BTRFS_MOUNT_POINT}/@snapshots"
    subvols=("${REMOTE_SUBVOLUMES[@]}")

    read -rs -p "$(_remote_sudo_prompt "$host")" SRC_PW
    echo >&2

    _src_run "mountpoint -q '${REMOTE_BTRFS_MOUNT_POINT}' || mount '${REMOTE_BTRFS_MOUNT_POINT}'" || \
      _die "failed to ensure ${REMOTE_BTRFS_MOUNT_POINT} is mounted on ${host}"
  else
    _ensure_btrfs_mounted
    label="$HOST_LABEL"
    snapshots_dir="${BTRFS_MOUNT_POINT}/@snapshots"
    subvols=("${SUBVOLUMES[@]}")
  fi

  local parent_link="${snapshots_dir}/trunk_${trunk_id}"
  local err_parent_dangling
  if [ -n "$host" ]; then
    err_parent_dangling="trunk_${trunk_id} tracking symlink on ${host} is dangling"
  else
    err_parent_dangling="${parent_link} is dangling"
  fi

  local set_timestamp
  if [ -n "$set_name" ]; then
    set_timestamp="$set_name"
    if ! _src_run "test -d '${snapshots_dir}/${set_timestamp}'"; then
      if [ -n "$host" ]; then
        _die "snapshot set not found on ${host}: ${set_timestamp}"
      else
        _die "no such snapshot set: ${snapshots_dir}/${set_timestamp}"
      fi
    fi
  else
    local latest_link="${snapshots_dir}/latest" resolved_latest err_no_latest err_latest_dangling
    if [ -n "$host" ]; then
      err_no_latest="no latest snapshot set found on ${host}"
      err_latest_dangling="latest snapshot symlink on ${host} is dangling"
    else
      err_no_latest="no ${latest_link} symlink found"
      err_latest_dangling="${latest_link} is dangling"
    fi
    resolved_latest=$(_src_run "readlink -f '${latest_link}'" 2>/dev/null || true)
    [ -n "$resolved_latest" ] || _die "$err_no_latest"
    _src_run "test -d '${resolved_latest}'" || _die "$err_latest_dangling"
    set_timestamp=$(basename "$resolved_latest")
  fi

  local parent_timestamp=""
  if _src_run "test -e '${parent_link}' || test -L '${parent_link}'"; then
    local resolved_parent
    resolved_parent=$(_src_run "readlink -f '${parent_link}'" 2>/dev/null || true)
    if [ -n "$resolved_parent" ] && _src_run "test -d '${resolved_parent}'"; then
      parent_timestamp=$(basename "$resolved_parent")
    else
      _die "$err_parent_dangling"
    fi
  fi

  local target_host_dir="${TRUNK_MOUNT_POINT}/@${label}"
  _ensure_trunk_host_subvol "$target_host_dir"

  local target_set_dir="${target_host_dir}/${set_timestamp}"
  if [ -e "$target_set_dir" ] || [ -L "$target_set_dir" ]; then
    _die "trunk snapshot set already exists: ${target_set_dir}"
  fi
  mkdir "$target_set_dir"

  local subvol current_path parent_path send_cmd kind
  for subvol in "${subvols[@]}"; do
    current_path=$(_snapshot_subvol_path "${snapshots_dir}/${set_timestamp}" "$set_timestamp" "$label" "$subvol")
    if ! _src_run "test -e '${current_path}'"; then
      if [ -n "$host" ]; then
        _error "expected remote snapshot not found: ${host}:${current_path}"
        return 1
      fi
      _die "expected snapshot not found: ${current_path}"
    fi

    parent_path=""
    # A newer tracking target cannot be an incremental parent for an older selected set.
    if [ -n "$parent_timestamp" ] && [[ "$parent_timestamp" < "$set_timestamp" ]]; then
      local candidate
      candidate=$(_snapshot_subvol_path "${snapshots_dir}/${parent_timestamp}" "$parent_timestamp" "$label" "$subvol")
      _src_run "test -e '${candidate}'" && parent_path="$candidate"
    fi

    _info "Backing up ${host:+${host}:}${subvol} (${set_timestamp}) to ${target_set_dir} ..."
    if [ -n "$parent_path" ]; then
      send_cmd="btrfs send -p '${parent_path}' '${current_path}'"
      kind="incremental"
    else
      send_cmd="btrfs send '${current_path}'"
      kind="full"
    fi

    if ! _src_send_receive "$send_cmd" "$target_set_dir"; then
      if [ -n "$host" ]; then
        _error "send/receive failed for ${host}:${subvol} -- any partially-received data under ${target_set_dir} requires clean up"
      else
        _error "${kind} send/receive failed for ${subvol} -- any partially-received data under ${target_set_dir} requires clean up"
      fi
      return 1
    fi
  done

  local src_set_dir="${snapshots_dir}/${set_timestamp}"
  _copy_set_metadata "$src_set_dir" "$target_set_dir" || return 1

  if [ -n "$host" ]; then
    _info "setting trunk_${trunk_id} -> ${set_timestamp} on ${host}"
    local symlink_cmd="if [ -e '${parent_link}' ] && [ ! -L '${parent_link}' ]; then exit 1; fi; ln -sfn '${set_timestamp}' '${parent_link}'"
    if ! _src_run "$symlink_cmd"; then
      _warn "backup succeeded, but could not update remote trunk_${trunk_id} symlink on ${host}"
    fi
  else
    _info "Setting trunk_${trunk_id} -> ${set_timestamp}"
    _update_symlink "$set_timestamp" "$parent_link" || true
  fi

  _info "Backed up ${label}/${set_timestamp}${host:+ (remote: ${host})} to trunk (id: ${trunk_id})"
}

cmd_trunk_list() {
  [ $# -le 1 ] || _die "trunk list: usage: trunk list [HOST]"

  local label="${1:-$HOST_LABEL}"
  case "$label" in
    --*) _die "trunk list: HOST is a positional argument, not a flag" ;;
  esac

  _ensure_trunk_mounted

  local host_dir="${TRUNK_MOUNT_POINT}/@${label}"
  if [ ! -d "$host_dir" ]; then
    _info "No trunk backups found for host '${label}'."
    return
  fi

  _require_btrctl_marker "$host_dir"

  local trunk_host="trunk/${label}"
  local host_width=${#trunk_host}
  [ "$host_width" -ge 4 ] || host_width=4
  printf '%s%-*s  %-20s  %s%s\n' \
    "$OUT_BOLD" "$host_width" "HOST" "SET" "TAG" "$OUT_RESET"
  local found=0 d set_name tag
  for d in "$host_dir"/*/; do
    set_name=$(basename "$d")
    _is_set_name "$set_name" || continue
    tag=$(_read_tag "${d%/}")
    printf '%-*s  %-20s  %s\n' "$host_width" "$trunk_host" "$set_name" "$tag"
    found=1
  done
  [ "$found" -eq 1 ] || _info "No snapshot sets found for host '${label}'."
}

cmd_trunk_rm() {
  [ $# -eq 1 ] || _die "trunk rm: usage: trunk rm HOST/SET_NAME"
  local arg="$1"
  case "$arg" in
    */*) : ;;
    *) _die "trunk rm: expected HOST/SET_NAME (e.g. remotehost/2025-01-15-120000)" ;;
  esac
  local host_label="${arg%%/*}"
  local set_name="${arg#*/}"
  [ -n "$host_label" ] && [ -n "$set_name" ] || _die "trunk rm: expected HOST/SET_NAME"

  _ensure_trunk_mounted

  local host_dir="${TRUNK_MOUNT_POINT}/@${host_label}"
  [ -d "$host_dir" ] || _die "no such trunk host: ${host_dir}"
  _require_btrctl_marker "$host_dir"

  local set_dir="${host_dir}/${set_name}"
  [ -d "$set_dir" ] || _die "no such trunk snapshot set: ${set_dir}"

  _delete_set_dir "$set_dir" || return 1
  _info "Removed trunk snapshot set: ${host_label}/${set_name}"
}

cmd_config() {
  echo "CONF_FILE=${CONF_FILE}"
  echo "CONF_OVERLAY_FILE=${CONF_OVERLAY_FILE}"
  echo "HOST_LABEL=${HOST_LABEL}"
  echo "BTRFS_MOUNT_POINT=${BTRFS_MOUNT_POINT}"
  echo "SUBVOLUMES=(${SUBVOLUMES[*]})"
  echo "TRUNK_MOUNT_POINT=${TRUNK_MOUNT_POINT}"
}

cmd_help() {
  local c_reset='' c_bold='' c_var=''
  if [ -t 1 ] && [ -z "${NO_COLOR:-}" ]; then
    c_reset=$'\033[0m'
    c_bold=$'\033[1m'
    c_var=$'\033[33m'
  fi

  cat <<EOF

${c_bold}btrctl${c_reset} - Btrfs snapshot and trunk backup tool

${c_bold}USAGE:${c_reset}
  ${c_bold}btrctl${c_reset} <command> [options]

${c_bold}COMMANDS:${c_reset}
  ${c_bold}mount${c_reset} [--host ${c_var}HOST${c_reset}]
  ${c_bold}umount|unmount${c_reset} [--host ${c_var}HOST${c_reset}]
  ${c_bold}snapshot${c_reset} [--tag ${c_var}NAME${c_reset}] [--host ${c_var}HOST${c_reset}]
  ${c_bold}list${c_reset} [--host ${c_var}HOST${c_reset}]
  ${c_bold}latest${c_reset} [--host ${c_var}HOST${c_reset}]
  ${c_bold}rm${c_reset} ${c_var}SET_NAME${c_reset} [--host ${c_var}HOST${c_reset}]
  ${c_bold}tag${c_reset} ${c_var}SET_ID${c_reset} ${c_var}TAG_NAME${c_reset} [--host ${c_var}HOST${c_reset}]

  ${c_bold}trunk id${c_reset}
  ${c_bold}trunk backup${c_reset} [${c_var}SET_NAME${c_reset}] [--host ${c_var}HOST${c_reset}]
  ${c_bold}trunk list${c_reset} [${c_var}HOST${c_reset}]
  ${c_bold}trunk rm${c_reset} ${c_var}HOST${c_reset}/${c_var}SET_NAME${c_reset}

  ${c_bold}config${c_reset}
  ${c_bold}help${c_reset}, ${c_bold}-h${c_reset}, ${c_bold}--help${c_reset}

EOF
}

main() {
  if [ "${1:-}" = "--remote-label" ]; then
    _consume_opt_value REMOTE_LABEL "$@"
    shift 2
  fi

  local cmd="${1:-}"
  case "$cmd" in
    "")                    cmd_help; exit 1  ;;
    help|-h|--help)        cmd_help          ;;
    mount)          shift; cmd_mount "$@"    ;;
    umount|unmount) shift; cmd_umount "$@"   ;;
    snapshot)       shift; cmd_snapshot "$@" ;;
    list)           shift; cmd_list "$@"     ;;
    latest)         shift; cmd_latest "$@"   ;;
    rm)             shift; cmd_rm "$@"       ;;
    tag)            shift; cmd_tag "$@"      ;;
    config)         shift; cmd_config "$@"   ;;
    trunk)
      shift
      local sub="${1:-}"
      case "$sub" in
        id)             shift; cmd_trunk_id "$@"     ;;
        backup)         shift; cmd_trunk_backup "$@" ;;
        list)           shift; cmd_trunk_list "$@"   ;;
        rm)             shift; cmd_trunk_rm "$@"     ;;
        *) _die "unknown trunk subcommand: ${sub:-<none>}" ;;
      esac ;;
    *) _die "unknown command: ${cmd}" ;;
  esac
}

[ "${BASH_SOURCE[0]}" = "${0}" ] && main "$@"
